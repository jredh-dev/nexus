{
    "swagger": "2.0",
    "info": {
        "description": "Count-based secret admission service. Submit secrets and discover equivalence.",
        "title": "nexus-secrets API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8081",
    "basePath": "/",
    "paths": {
        "/api/exposed": {
            "get": {
                "description": "Returns a rotating plain-text page of secrets that have been admitted more than once.",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "secrets"
                ],
                "summary": "Get exposed secrets",
                "responses": {
                    "200": {
                        "description": "Plain text wall of exposed secrets",
                        "schema": {
                            "type": "string"
                        },
                        "headers": {
                            "X-Exposed-Page": {
                                "type": "int",
                                "description": "Current page index"
                            },
                            "X-Exposed-Pages": {
                                "type": "int",
                                "description": "Total number of pages"
                            },
                            "X-Exposed-Total": {
                                "type": "int",
                                "description": "Total number of exposed secrets"
                            }
                        }
                    }
                }
            }
        },
        "/api/riddle": {
            "get": {
                "description": "Returns the riddle that explains the secrets game, along with current stats.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "secrets"
                ],
                "summary": "Get the riddle",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/secrets": {
            "get": {
                "description": "Returns all secrets in randomized order.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "secrets"
                ],
                "summary": "List all secrets",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/github_com_jredh-dev_nexus_services_secrets_internal_store.Secret"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Submit a value to be checked for equivalence. If no matching",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "secrets"
                ],
                "summary": "Submit a secret",
                "parameters": [
                    {
                        "description": "Secret submission",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.submitReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_jredh-dev_nexus_services_secrets_internal_store.SubmitResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/secrets/{id}": {
            "get": {
                "description": "Returns a single secret by its ID.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "secrets"
                ],
                "summary": "Get a secret by ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Secret ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_jredh-dev_nexus_services_secrets_internal_store.Secret"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/stats": {
            "get": {
                "description": "Returns counts of total secrets, still-secret entries, exposed entries, and lens count.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "secrets"
                ],
                "summary": "Get aggregate stats",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_jredh-dev_nexus_services_secrets_internal_store.Stats"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "github_com_jredh-dev_nexus_services_secrets_internal_store.Secret": {
            "type": "object",
            "properties": {
                "count": {
                    "description": "how many times admitted",
                    "type": "integer"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "last_admit_at": {
                    "description": "most recent submission",
                    "type": "string"
                },
                "submitted_by": {
                    "description": "first submitter",
                    "type": "string"
                },
                "value": {
                    "type": "string"
                }
            }
        },
        "github_com_jredh-dev_nexus_services_secrets_internal_store.Stats": {
            "type": "object",
            "properties": {
                "lenses": {
                    "type": "integer"
                },
                "not_secrets": {
                    "description": "count \u003e 1",
                    "type": "integer"
                },
                "secrets": {
                    "description": "count \u003c= 1",
                    "type": "integer"
                },
                "total": {
                    "type": "integer"
                }
            }
        },
        "github_com_jredh-dev_nexus_services_secrets_internal_store.SubmitResult": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "secret": {
                    "$ref": "#/definitions/github_com_jredh-dev_nexus_services_secrets_internal_store.Secret"
                },
                "was_new": {
                    "type": "boolean"
                }
            }
        },
        "internal_handlers.submitReq": {
            "type": "object",
            "properties": {
                "submitted_by": {
                    "type": "string"
                },
                "value": {
                    "type": "string"
                }
            }
        }
    }
}