{
    "swagger": "2.0",
    "info": {
        "description": "iCal calendar subscription and management service.",
        "title": "nexus-cal API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8082",
    "basePath": "/",
    "paths": {
        "/api/events": {
            "post": {
                "description": "Adds a new event to a calendar feed. Dates must be RFC 3339 format.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "events"
                ],
                "summary": "Create a calendar event",
                "parameters": [
                    {
                        "description": "Event creation request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.createEventReq"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/github_com_jredh-dev_nexus_services_cal_internal_database.Event"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/events/{id}": {
            "delete": {
                "description": "Removes a single event by its ID.",
                "tags": [
                    "events"
                ],
                "summary": "Delete a calendar event",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Event ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/feeds": {
            "get": {
                "description": "Returns all calendar feeds.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "feeds"
                ],
                "summary": "List all calendar feeds",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/github_com_jredh-dev_nexus_services_cal_internal_database.Feed"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Creates a new calendar feed with an optional URL slug.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "feeds"
                ],
                "summary": "Create a calendar feed",
                "parameters": [
                    {
                        "description": "Feed creation request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.createFeedReq"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.createFeedResp"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "409": {
                        "description": "Slug already in use",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/feeds/{id}": {
            "delete": {
                "description": "Removes a feed and all its associated events.",
                "tags": [
                    "feeds"
                ],
                "summary": "Delete a calendar feed",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Feed ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/feeds/{id}/events": {
            "get": {
                "description": "Returns all events belonging to a calendar feed.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "events"
                ],
                "summary": "List events for a feed",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Feed ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/github_com_jredh-dev_nexus_services_cal_internal_database.Event"
                            }
                        }
                    }
                }
            }
        },
        "/{token}.ics": {
            "get": {
                "description": "Returns an iCal feed for the given token. Used by calendar clients (webcal://).",
                "produces": [
                    "text/calendar"
                ],
                "tags": [
                    "subscription"
                ],
                "summary": "Subscribe to calendar feed",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Feed token or slug",
                        "name": "token",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "iCal feed content",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Feed not found",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "github_com_jredh-dev_nexus_services_cal_internal_database.Event": {
            "type": "object",
            "properties": {
                "all_day": {
                    "type": "boolean"
                },
                "categories": {
                    "description": "comma-separated",
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "deadline": {
                    "description": "optional deadline (used as DTSTART if set, with VALARM)",
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "end": {
                    "description": "nil = no end time (all-day or point-in-time)",
                    "type": "string"
                },
                "feed_id": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "location": {
                    "type": "string"
                },
                "start": {
                    "type": "string"
                },
                "status": {
                    "description": "TENTATIVE, CONFIRMED, CANCELLED",
                    "type": "string"
                },
                "summary": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            }
        },
        "github_com_jredh-dev_nexus_services_cal_internal_database.Feed": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "token": {
                    "description": "unguessable token for subscription URL",
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "internal_handlers.createEventReq": {
            "type": "object",
            "properties": {
                "all_day": {
                    "type": "boolean"
                },
                "categories": {
                    "type": "string"
                },
                "deadline": {
                    "description": "RFC 3339, optional",
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "end": {
                    "description": "RFC 3339, optional",
                    "type": "string"
                },
                "feed_id": {
                    "type": "string"
                },
                "location": {
                    "type": "string"
                },
                "start": {
                    "description": "RFC 3339",
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "summary": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            }
        },
        "internal_handlers.createFeedReq": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "slug": {
                    "description": "optional: readable URL slug (e.g. \"my-calendar\")",
                    "type": "string"
                }
            }
        },
        "internal_handlers.createFeedResp": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "token": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            }
        }
    }
}